# Environment variables for development
# Copy this file to .env and fill in your own keys.
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id
VITE_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
VITE_EMAILJS_USER_ID=your-emailjs-user-id

# Firebase Ayarları
# Firebase Console > Project Settings > General > Your apps kısmından alın
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OSOS (Otomatik Sayaç Okuma Sistemi) Ayarları
# OSOS Portal'dan canlı veri çekmek için bu bilgileri doldurun

# Dağıtım Şirketi (EDAŞ)
# Seçenekler: toroslar, baskent, ayedas, gedas, sedas
OSOS_DAGITIM_SIRKETI=toroslar

# OSOS Portal Kullanıcı Bilgileri
# (EDAŞ'tan başvuru ile alınır - OSOS_ENTEGRASYON.md dosyasına bakın)
OSOS_KULLANICI_ADI=
OSOS_SIFRE=

# Sayaç Numarası
OSOS_SAYAC_NO=

# Backend URL
BACKEND_URL=http://localhost:3001/api

# Supabase Ayarları
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Bordro Şifresi
VITE_BORDRO_PASSWORD=your-bordro-password

