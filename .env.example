# Environment variables for development
# Copy this file to .env and fill in your own keys.
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id
VITE_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
VITE_EMAILJS_USER_ID=your-emailjs-user-id

# OSOS (Otomatik Sayaç Okuma Sistemi) Ayarları
# OSOS Portal'dan canlı veri çekmek için bu bilgileri doldurun

# Dağıtım Şirketi (EDAŞ)
# Seçenekler: toroslar, baskent, ayedas, gedas, sedas
OSOS_DAGITIM_SIRKETI=toroslar

# OSOS Portal Kullanıcı Bilgileri
# (EDAŞ'tan başvuru ile alınır - OSOS_ENTEGRASYON.md dosyasına bakın)
OSOS_KULLANICI_ADI=
OSOS_SIFRE=

# Sayaç Numarası
OSOS_SAYAC_NO=

# Backend URL
BACKEND_URL=http://localhost:3001/api

# Supabase Ayarları
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Opsiyonel alias'lar (Next.js / Expo örneklerinden gelen adlar)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_publishable_key

